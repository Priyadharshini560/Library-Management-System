#include<iostream>
#include<fstream>
#include<vector>
#include<limits>
using namespace std;

class Book {
public:
    int id;
    string title;
    string author;
    bool issued;

    Book() {}

    Book(int i,string t,string a,bool iss=false) {
        id=i;
        title=t;
        author=a;
        issued=iss;
    }
};

vector<Book>library;


void loadFromFile() {
    ifstream file("library.txt");
    library.clear();

    int id;
    string title, author;
    bool issued;

    while(file>>id) {
        file.ignore();
        getline(file, title,'|');
        getline(file, author,'|');
        file>>issued;

        library.push_back(Book(id, title, author, issued));
    }

    file.close();
}


void saveToFile() {
    ofstream file("library.txt");

    for(auto &b : library){
        file<<b.id<<"|"<<b.title<<"|"<<b.author<<"|"<<b.issued<<endl;
    }

    file.close();
}

void addBook() {
    int id;
    string title,author;

    cout<<"Enter Book ID: ";
    cin>>id;
    cin.ignore();

    cout<<"Enter Title: ";
    getline(cin,title);

    cout<<"Enter Author: ";
    getline(cin,author);

    library.push_back(Book(id,title,author));
    saveToFile();

    cout<<"Book added successfully!\n";
}


void showBooks() {
    if(library.empty()) {
        cout<<"No books available.\n";
        return;
    }

    for(auto &b : library) {
        cout<<"\nID: "<<b.id<<"\nTitle: "<<b.title<<"\nAuthor: "<<b.author<<"\nStatus: "<<(b.issued? "Issued" : "Available")<< "\n";
    }
}


void issueBook() {
    int id;
    cout<<"Enter Book ID to issue: ";
    cin>>id;

    for(auto &b:library) {
        if(b.id==id && !b.issued) {
            b.issued=true;
            saveToFile();
            cout<<"Book issued successfully!\n";
            return;
        }
    }

    cout<<"Book not available!\n";
}


void returnBook() {
    int id;
    cout<<"Enter Book ID to return: ";
    cin>>id;

    for(auto &b:library) {
        if(b.id==id && b.issued) {
            b.issued=false;
            saveToFile();
            cout<<"Book returned successfully!\n";
            return;
        }
    }

    cout<<"Invalid Book ID!\n";
}


void searchBook() {
    string key;
    cin.ignore(numeric_limits<streamsize>::max(),'\n');

    cout<<"Enter title or author: ";
    getline(cin,key);

    bool found=false;

    for(auto &b:library) {
        if(b.title.find(key)!=string::npos ||
            b.author.find(key)!=string::npos) {

            cout<<"\nFound:\n";
            cout<<"ID: "<<b.id<<"\nTitle: "<<b.title<<"\nAuthor: "<<b.author<<"\nStatus: "<<(b.issued ? "Issued":"Available")<<"\n";

            found=true;
        }
    }

    if(!found)
        cout<<"No matching book found!\n";
}

int main() {
    int choice;

    loadFromFile();

    do {
        cout<<"\n--- Library Menu ---\n";
        cout<<"1. Add Book\n";
        cout<<"2. Show Books\n";
        cout<<"3. Issue Book\n";
        cout<<"4. Return Book\n";
        cout<<"5. Search Book\n";
        cout<<"6. Exit\n";
        cout<<"Enter choice: ";
        cin>>choice;

  switch(choice) {
            case 1: addBook(); break;
            case 2: showBooks(); break;
            case 3: issueBook(); break;
            case 4: returnBook(); break;
            case 5: searchBook(); break;
            case 6: cout<<"Exiting...\n"; break;
            default:cout<<"Invalid choice!\n";
        }

    } while(choice!=6);

    return 0;
}
